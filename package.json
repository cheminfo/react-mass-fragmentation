{
  "name": "react-mass-fragmentation",
  "version": "1.0.0",
  "description": "React component to display mass fragmentation of peptides and nucleotides",
  "license": "MIT",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "npm run tsc && cheminfo-build --entry lib/index.js --root MassSequenceSVG",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf lib",
    "dev": "vite",
    "eslint": "eslint src demo",
    "eslint-fix": "npm run eslint -- --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check src demo",
    "prettier-write": "prettier --write src demo",
    "preview": "vite preview",
    "test": "vitest && npm run eslint && npm run prettier && npm run check-types",
    "test-only": "vitest",
    "tsc": "npm run clean && tsc --project tsconfig.build.json"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "dependencies": {
    "chemical-groups": "^2.2.3",
    "mf-utilities": "^3.5.4",
    "nucleotide": "^3.2.14",
    "peptide": "^2.3.14"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cheminfo-build": "^1.3.2",
    "eslint": "^9.19.0",
    "eslint-config-cheminfo-react": "^19.2.0",
    "eslint-config-cheminfo-typescript": "^21.2.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.8.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
